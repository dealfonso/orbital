{
  "name": "orbital",
  "version": "1.1.0",
  "description": "Orbital (ORB) is a lightweight framework to build interactive HTML/CSS/JavaScript apps with screen navigation, state flows and i18n.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "jsdelivr": "./dist/index.js",
  "unpkg": "./dist/index.js",
  "style": "./dist/style.css",
  "exports": {
    ".": "./dist/index.js",
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "node ./scripts/build-dist.mjs",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.10"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT",
  "keywords": [
    "framework",
    "webapp",
    "pwa",
    "javascript",
    "state-machine",
    "i18n",
    "navigation"
  ]
}